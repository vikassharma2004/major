# Database
MONGO_URI=mongodb://localhost:27017/careernav

# Server Configuration
PORT=5000
NODE_ENV=development
VERSION=/api/v1

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secure_refresh_secret_key_change_this_in_production

# Redis Configuration (Optional - for session management and rate limiting)
REDIS_URL=redis://localhost:6379
# OR individual Redis config
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="CareerNav <your-email@gmail.com>"

# Alternative Email Service (Resend)
RESEND_API_KEY=your_resend_api_key

# AI Services
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key

# Logging
LOG_LEVEL=info

# Session Configuration
SESSION_SECRET=your_session_secret_key_change_this_in_production

# Security
BCRYPT_ROUNDS=12